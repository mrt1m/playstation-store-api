{
  "name": "mrt1m/playstation-store-api",
  "description": "A simple wrapper for working with PlayStation Store API",
  "keywords": ["api-client", "playstation", "playstation-store", "php8"],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Timur Ishmukhametov",
      "email": "job.mrt1m@gmail.com"
    }
  ],
  "require": {
    "ext-json": "*",
    "php": ">=8.1",
    "psr/http-client": "^1.0",
    "guzzlehttp/psr7": "^2.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.51",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "PlaystationStoreApi\\": "src/"
    }
  },
  "scripts": {
    "lint": [
      "phpstan analyse",
      "php-cs-fixer check --diff src"
    ],
    "lint-fix": "php-cs-fixer fix src"
  }
}
